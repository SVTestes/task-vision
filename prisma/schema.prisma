// Task Vision — Schema do banco de dados
// Inspirado na estrutura kanban: Workspace > Board > List > Card
// Auth: sem cadastro público — admin cria usuários manualmente
// Cascade deletes: deletar pai remove todos os filhos automaticamente

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Autenticação ────────────────────────────────────────

enum UserRole {
  ADMIN
  PROJECT_OWNER
  MEMBER
}

enum NotificationType {
  COMMENT_ADDED           // Alguém comentou num card onde o user é membro
  MEMBER_ADDED            // O user foi adicionado como membro de um card
  DUE_DATE_SOON           // Card com due date vencendo em 24h
  DUE_DATE_OVERDUE        // Card com due date vencido
  CARD_MOVED              // Card onde o user é membro foi movido de lista
  CHECKLIST_ITEM_ASSIGNED // User foi atribuído como responsável por um item de checklist
  CHECKLIST_ITEM_OVERDUE  // Item de checklist com dueDate vencido
  CARD_COMPLETED          // Cartão foi marcado como concluído
  CARD_UNCOMPLETED        // Cartão foi desmarcado (marcado como não concluído)
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  username          String?   @unique
  password          String    // bcrypt hash
  name              String
  role              UserRole  @default(MEMBER)
  isDeactivated     Boolean   @default(false)
  passwordChangedAt DateTime?
  image             String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  sessions         Session[]
  ownedWorkspaces  Workspace[]       @relation("WorkspaceOwner")
  workspaceMembers WorkspaceMember[]
  sentInvitations  Invitation[]      @relation("InvitationSender")
  createdCards     Card[]            @relation("CardCreator")
  cardMemberships  CardMember[]      @relation("CardMemberUser")
  comments         Comment[]         @relation("CommentAuthor")
  activities       Activity[]        @relation("ActivityUser")
  attachments      Attachment[]      @relation("AttachmentCreator")
  receivedNotifications    Notification[]  @relation("NotificationReceiver")
  createdNotifications     Notification[]  @relation("NotificationCreator")
  assignedChecklistItems   ChecklistItem[] @relation("ChecklistItemAssignee")
}

model Session {
  id            String   @id @default(cuid())
  accessToken   String   @unique
  httpOnlyToken String   @unique
  userId        String
  remoteAddress String?
  userAgent     String?
  createdAt     DateTime @default(now())
  expiresAt     DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Kanban ──────────────────────────────────────────────

model Workspace {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  description         String?  @db.VarChar(1024)
  backgroundGradient  String?
  ownerId             String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  owner       User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members     WorkspaceMember[]
  boards      Board[]
  invitations Invitation[]

  @@index([ownerId])
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Board {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  background  String?
  position    Float    @default(1000)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lists         List[]
  labels        Label[]
  notifications Notification[]

  @@index([workspaceId])
}

model List {
  id        String   @id @default(cuid())
  boardId   String
  title     String
  position  Float    @default(1000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([boardId])
}

model Card {
  id             String    @id @default(cuid())
  listId         String
  title          String
  description    String?   @db.Text
  position       Float     @default(1000)
  dueDate        DateTime?
  isDueCompleted Boolean   @default(false)
  creatorId      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  list          List           @relation(fields: [listId], references: [id], onDelete: Cascade)
  creator       User?          @relation("CardCreator", fields: [creatorId], references: [id])
  labels        CardLabel[]
  checklists    Checklist[]
  attachments   Attachment[]
  members       CardMember[]
  comments      Comment[]
  activities    Activity[]
  notifications Notification[]

  @@index([listId])
}

// ─── Etiquetas ───────────────────────────────────────────

model Label {
  id        String   @id @default(cuid())
  boardId   String
  name      String?
  color     String   // "red", "blue", "green", "yellow", "purple", "orange", "pink", "cyan"
  position  Float    @default(1000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards CardLabel[]

  @@index([boardId])
}

model CardLabel {
  id      String @id @default(cuid())
  cardId  String
  labelId String

  card  Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([cardId, labelId])
}

// ─── Checklists ──────────────────────────────────────────

model Checklist {
  id        String   @id @default(cuid())
  cardId    String
  title     String   @default("Checklist")
  position  Float    @default(1000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  card  Card            @relation(fields: [cardId], references: [id], onDelete: Cascade)
  items ChecklistItem[]

  @@index([cardId])
}

model ChecklistItem {
  id          String    @id @default(cuid())
  checklistId String
  title       String
  isCompleted Boolean   @default(false)
  position    Float     @default(1000)
  assigneeId  String?   // Responsável pelo item (1:1)
  dueDate     DateTime? // Prazo específico do item
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  checklist Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  assignee  User?     @relation("ChecklistItemAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([checklistId])
  @@index([assigneeId])
  @@index([dueDate])
}

// ─── Anexos ──────────────────────────────────────────────

model Attachment {
  id        String   @id @default(cuid())
  cardId    String
  creatorId String?
  name      String
  url       String
  type      String   @default("link") // "link" ou "file"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  card    Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  creator User? @relation("AttachmentCreator", fields: [creatorId], references: [id])

  @@index([cardId])
}

// ─── Membros do Card ─────────────────────────────────────

model CardMember {
  id        String   @id @default(cuid())
  cardId    String
  userId    String
  createdAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation("CardMemberUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cardId, userId])
}

// ─── Comentários ─────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  cardId    String
  userId    String
  text      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  card          Card           @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user          User           @relation("CommentAuthor", fields: [userId], references: [id])
  notifications Notification[]

  @@index([cardId])
}

// ─── Histórico de Atividade ──────────────────────────────

model Activity {
  id        String   @id @default(cuid())
  cardId    String
  userId    String?
  type      String   // "createCard", "moveCard", "addMember", "addLabel", etc.
  data      Json     @default("{}")
  createdAt DateTime @default(now())

  card Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User? @relation("ActivityUser", fields: [userId], references: [id])

  @@index([cardId])
}

// ─── Convites ────────────────────────────────────────────

model Invitation {
  id          String   @id @default(cuid())
  workspaceId String
  email       String
  token       String   @unique
  invitedById String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation("InvitationSender", fields: [invitedById], references: [id])

  @@index([workspaceId])
  @@index([email])
}

// ─── Notificações ────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String           // Quem recebe a notificação
  creatorId String?          // Quem causou a ação (null = sistema)
  cardId    String           // Card relacionado
  boardId   String           // Board (desnormalizado para query rápida)
  commentId String?          // Comentário relacionado (se aplicável)
  type      NotificationType
  data      Json             @default("{}")
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user    User     @relation("NotificationReceiver", fields: [userId], references: [id], onDelete: Cascade)
  creator User?    @relation("NotificationCreator", fields: [creatorId], references: [id])
  card    Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  board   Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([cardId])
}
